# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# Only the names matter here; leave values blank.

# PostHog analytics (src/components/posthog.astro, rendered in the layouts).
# PUBLIC_ prefix = exposed to the browser by Astro for client-side capture.
PUBLIC_POSTHOG_PROJECT_TOKEN=   # phc_... project/capture token
PUBLIC_POSTHOG_HOST=            # e.g. https://us.i.posthog.com

# Contact form (functions/api/kontakt.ts) — sends the German /de/kontakt inquiries
# via Resend. In production this is set as a Cloudflare Pages env var instead.
RESEND_API_KEY=

# --- optional, not yet used ---
# To READ analytics back out (content-seo loop's traffic collector), you need a
# PostHog personal API key with read scope — distinct from the capture token above.
# POSTHOG_PERSONAL_API_KEY=   # phx_...
