---
import MainNav from '../components/MainNav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  author?: string;
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  type?: 'website' | 'article';
}

const {
  title = 'Khaled Garbaya',
  description = 'Engineering Leader, Developer and educator. I write about web development, software engineering and leadership.',
  image = 'https://res.cloudinary.com/kgarbaya/image/upload/co_rgb:0891B2,l_text:Quicksand_55_bold:I write about web development leadership and productivity,g_north_west,x_436,y_200,w_670,c_fit/v1727002971/og-image.png',
  author = 'Khaled Garbaya',
  keywords = 'web development, software engineering, leadership, javascript, typescript, ai, devops',
  publishedTime,
  modifiedTime,
  articleTags = [],
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="w-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Enhanced SEO Meta Tags -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="theme-color" content="#0891b2" />
    
    <!-- Citation Meta Tags for Academic/LLM Indexing -->
    {type === 'article' && (
      <>
        <meta name="citation_title" content={title} />
        <meta name="citation_author" content={author} />
        {publishedTime && <meta name="citation_publication_date" content={publishedTime} />}
      </>
    )}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Khaled Garbaya" />
    <meta property="og:locale" content="en_US" />
    
    {type === 'article' && (
      <>
        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
        <meta property="article:author" content={author} />
        {articleTags.map(tag => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <meta property="twitter:creator" content="@khaled_garbaya" />
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://res.cloudinary.com" />
    
    <!-- RSS Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Khaled Garbaya - Blog" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Khaled Garbaya - TIL" href="/til-rss.xml" />

    <!-- LLM Discovery -->
    <link rel="alternate" type="text/plain" title="LLM Info" href="/llms.txt" />
    
    <!-- Theme initialization script - must run before content loads -->
    <script is:inline>
      function initTheme() {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();

        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }

        window.localStorage.setItem('theme', theme);
      }

      // Run immediately
      initTheme();

      // Run before view transition swap
      document.addEventListener('astro:before-swap', (ev) => {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          ev.newDocument.documentElement.classList.add('dark');
        } else {
          ev.newDocument.documentElement.classList.remove('dark');
        }
      });

      // Re-run after view transition
      document.addEventListener('astro:after-swap', initTheme);
    </script>
    
    <!-- WebMCP: Expose site tools to AI agents via browser -->
    <script is:inline>
      if (typeof navigator !== 'undefined' && navigator.modelContext) {
        navigator.modelContext.registerTool({
          name: 'search-content',
          description: 'Search blog posts and TIL entries by keyword. Returns matching titles, descriptions, URLs, and dates.',
          inputSchema: {
            type: 'object',
            properties: {
              query: { type: 'string', description: 'Search keyword or phrase' },
              type: { type: 'string', enum: ['all', 'blog', 'til'], description: 'Filter by content type', default: 'all' }
            },
            required: ['query']
          },
          async execute(params) {
            const res = await fetch('/api/content.json');
            const data = await res.json();
            const items = data.mainEntity.itemListElement;
            const q = params.query.toLowerCase();
            const filtered = items.filter(function(entry) {
              var item = entry.item;
              if (params.type === 'blog' && item['@type'] !== 'BlogPosting') return false;
              if (params.type === 'til' && item.articleSection !== 'Today I Learned') return false;
              return item.headline.toLowerCase().includes(q) ||
                     item.description.toLowerCase().includes(q) ||
                     (item.keywords && item.keywords.toLowerCase().includes(q));
            });
            return filtered.map(function(entry) {
              return { title: entry.item.headline, url: entry.item.url, description: entry.item.description, date: entry.item.datePublished };
            });
          }
        });

        navigator.modelContext.registerTool({
          name: 'list-recent-posts',
          description: 'Get the most recent blog posts and TIL entries.',
          inputSchema: {
            type: 'object',
            properties: {
              limit: { type: 'number', description: 'Number of items to return', default: 10 },
              type: { type: 'string', enum: ['all', 'blog', 'til'], description: 'Filter by content type', default: 'all' }
            }
          },
          async execute(params) {
            var limit = params.limit || 10;
            var res = await fetch('/api/content.json');
            var data = await res.json();
            var items = data.mainEntity.itemListElement;
            if (params.type === 'blog') items = items.filter(function(e) { return e.item['@type'] === 'BlogPosting'; });
            if (params.type === 'til') items = items.filter(function(e) { return e.item.articleSection === 'Today I Learned'; });
            return items.slice(0, limit).map(function(entry) {
              return { title: entry.item.headline, url: entry.item.url, description: entry.item.description, date: entry.item.datePublished };
            });
          }
        });

        navigator.modelContext.registerTool({
          name: 'get-site-info',
          description: 'Get metadata about this website: author, description, available feeds, and API endpoints.',
          inputSchema: { type: 'object', properties: {} },
          async execute() {
            return {
              name: 'Khaled Garbaya',
              description: 'Engineering Leader, Developer, and Educator. Technical blog about web development, AI, and software engineering.',
              author: 'Khaled Garbaya',
              url: 'https://khaledgarbaya.net',
              feeds: {
                blogRss: '/rss.xml',
                tilRss: '/til-rss.xml',
                sitemap: '/sitemap-index.xml'
              },
              apis: {
                contentGraph: '/api/content.json',
                llmsInfo: '/llms.txt',
                apiCatalog: '/.well-known/api-catalog'
              }
            };
          }
        });
      }
    </script>

    <ViewTransitions />
  </head>
  <body class="h-full zellige-pattern">
    <div class="py-6">
      <MainNav />
      <slot />
      <Footer />
    </div>
  </body>
</html>

