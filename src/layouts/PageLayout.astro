---
import BaseLayout from './BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import HeroScrub from '../components/HeroScrub.astro';
import PersonSchema from '../components/schemas/PersonSchema.astro';
import WebsiteSchema from '../components/schemas/WebsiteSchema.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  keywords?: string;
  showHero?: boolean;
  showImage?: boolean;
  eyebrow?: string;
  scrubBase?: string;
  plain?: boolean;
}

const {
  title,
  description,
  image = `https://res.cloudinary.com/kgarbaya/image/upload/co_rgb:0891B2,l_text:Quicksand_55_bold:${encodeURIComponent(description)},g_north_west,x_436,y_200,w_670,c_fit/v1727002971/og-image.png`,
  keywords = 'khaled garbaya, web development, software engineering, leadership',
  showHero = true,
  showImage = false,
  eyebrow,
  scrubBase,
  plain = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  keywords={keywords}
>
  <PersonSchema slot="head" />
  <WebsiteSchema slot="head" />
  
  <!-- START: Page -->
  <!-- CONTENT_TYPE: Page -->
  <!-- AUTHOR: Khaled Garbaya -->
  <div class:list={['w-full', !scrubBase && 'pt-24 sm:pt-32']}>
    {showHero && (
      <header
        class:list={[
          'flex flex-col-reverse items-start gap-10 md:flex-row md:items-center',
          scrubBase && 'relative min-h-[70svh] overflow-hidden py-24',
        ]}
      >
        {scrubBase && <HeroScrub base={scrubBase} />}
        <div class="relative z-10 flex-auto">
          <PageHero
            eyebrow={eyebrow}
            title={title.replace('Khaled Garbaya - ', '')}
            description={description}
          />
        </div>
        {showImage && (
          <img
            src="/Khaled_Garbaya_Colour.jpg"
            alt="Khaled Garbaya - Engineering Leader, Developer and Educator"
            width="400"
            height="400"
            loading="lazy"
            class="relative z-10 aspect-square object-cover rounded-2xl shadow-lg -rotate-3 px-6 sm:px-0 md:mr-10"
            itemprop="image"
          />
        )}
      </header>
    )}
    <main class:list={['px-6 sm:px-10', plain ? 'mt-6' : 'mt-20']}>
      <div class="mx-auto max-w-7xl">
        <article class:list={[!plain && 'prose dark:prose-invert prose-lg']}>
          <slot />
        </article>
      </div>
    </main>
  </div>
  <!-- END: Page -->
</BaseLayout>
