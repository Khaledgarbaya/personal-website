---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<div class="px-6 sm:px-10">
  <div class="mx-auto max-w-7xl">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="display-huge mt-6 text-[clamp(3rem,9vw,8rem)]">{title}</h1>
    <p class="mt-8 max-w-2xl text-lg text-muted-foreground">{description}</p>
  </div>
</div>
