---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 sm:px-10">
    <div class="flex items-center">
      {currentPath !== '/' ? (
        <a href="/" class="font-mono-ui text-sm tracking-wide transition hover:text-gold">
          ~/khaled-garbaya
        </a>
      ) : (
        <span class="font-mono-ui text-sm tracking-wide text-muted-foreground">~</span>
      )}
    </div>

    <button
      class="md:hidden z-50"
      id="menu-toggle"
      aria-label="Toggle menu"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div
      id="mobile-menu"
      class="fixed inset-0 bg-background/95 backdrop-blur-sm z-40 flex flex-col items-center justify-center transition-all duration-300 ease-in-out opacity-0 invisible md:static md:bg-transparent md:backdrop-blur-none md:flex-row md:justify-between md:opacity-100 md:visible"
    >
      <ul class="flex flex-col items-center space-y-4 md:flex-row md:space-y-0 md:space-x-2">
        <li>
          <a class="nav-link" href="/blog">Blog</a>
        </li>
        <li>
          <a class="nav-link" href="/til">TIL</a>
        </li>
        <li>
          <a class="nav-link" href="/about">About</a>
        </li>
        <li>
          <a class="nav-link" href="/uses">Uses</a>
        </li>
        <li>
          <a class="nav-link" href="/newsletter">Newsletter</a>
        </li>
      </ul>
      <div class="mt-4 md:mt-0 md:ml-4">
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<script>
  function setupMobileMenu() {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (menuToggle && mobileMenu && menuIcon && closeIcon) {
      // Remove old listeners by cloning the button
      const newToggle = menuToggle.cloneNode(true) as HTMLElement;
      menuToggle.parentNode?.replaceChild(newToggle, menuToggle);
      // Re-query the icons inside the clone — the originals are now detached
      const menuIcon = newToggle.querySelector('#menu-icon')!;
      const closeIcon = newToggle.querySelector('#close-icon')!;

      newToggle.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('invisible');

        if (isOpen) {
          mobileMenu.classList.add('opacity-0', 'invisible');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        } else {
          mobileMenu.classList.remove('opacity-0', 'invisible');
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
        }
      });
    }
  }

  // Setup on initial load
  setupMobileMenu();

  // Re-setup after view transitions
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
