---
interface Props {
  slug: string;
  title: string;
  description: string;
  published: Date;
  tags: string;
  type?: 'blog' | 'til';
}

const { slug, title, description, published, tags, type = 'blog' } = Astro.props;

// Parse tags from comma-separated string
const tagList = tags ? tags.split(',').map(tag => tag.trim()) : [];
const basePath = type === 'til' ? '/til' : '/blog';
---

<article class="group relative py-10">
  <div class="flex flex-wrap items-baseline gap-x-6 gap-y-2">
    <time
      class="font-mono-ui text-xs tracking-[0.15em] text-muted-foreground"
      datetime={published.toISOString()}
    >
      {published.toISOString().split('T')[0]}
    </time>
    <div class="flex flex-wrap gap-x-4">
      {tagList.map((tag: string) => (
        <a
          href={`${basePath}/tags/${tag}`}
          class="relative z-10 font-mono-ui text-xs tracking-wide text-muted-foreground transition hover:text-cerulean"
        >
          #{tag}
        </a>
      ))}
    </div>
  </div>
  <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-foreground transition-colors group-hover:text-gold sm:text-4xl lg:text-5xl">
    <a href={`${basePath}/${slug}`}>
      <span class="absolute inset-0" aria-hidden="true"></span>
      {title}
    </a>
  </h2>
  <p class="mt-4 max-w-2xl text-muted-foreground">
    {description}
  </p>
</article>
