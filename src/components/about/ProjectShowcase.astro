---
// Side-project showcase rows: big display names, mono status tags, and a
// hover shift — same register as the homepage writing index.
interface Project {
  name: string;
  status: string;
  description: string;
  stack?: string;
  href?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<ul>
  {projects.map((project, i) => {
    const Tag = project.href ? 'a' : 'div';
    return (
      <li class="reveal border-t border-border first:border-t-0" style={`--reveal-delay: ${i * 100}ms`}>
        <Tag
          href={project.href}
          class="group grid gap-x-12 gap-y-3 py-12 lg:grid-cols-[2fr_3fr]"
        >
          <div>
            <span class="font-mono-ui text-xs tracking-[0.2em] uppercase text-gold">
              {project.status}
            </span>
            <h3 class="mt-3 font-display text-4xl font-bold tracking-tight transition-transform duration-300 group-hover:translate-x-2 sm:text-5xl">
              {project.name}
            </h3>
          </div>
          <div class="self-center">
            <p class="max-w-xl text-lg text-muted-foreground">{project.description}</p>
            {project.stack && (
              <p class="mt-3 font-mono-ui text-xs tracking-wide text-muted-foreground/70">
                {project.stack}
              </p>
            )}
          </div>
        </Tag>
      </li>
    );
  })}
</ul>
