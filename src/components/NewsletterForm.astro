---
---

<form
  action="https://app.convertkit.com/forms/1036024/subscriptions"
  method="post"
  class="border-t border-border pt-10"
>
  <p class="eyebrow">~ % subscribe</p>
  <h2 class="display-huge mt-6 text-[clamp(2rem,5vw,4.5rem)]">
    Get the next post.
  </h2>
  <p class="mt-4 max-w-xl text-muted-foreground">
    New writing on agentic workflows and engineering leadership, straight to
    your inbox. Unsubscribe at any time.
  </p>
  <div class="mt-8 flex max-w-xl">
    <input
      id="email_address"
      name="email_address"
      aria-label="Email Address"
      placeholder="Email address"
      required
      class="min-w-0 flex-auto appearance-none border-b border-border bg-transparent px-1 py-3 font-mono-ui text-sm placeholder:text-muted-foreground focus:border-gold focus:outline-none"
      type="email"
    />
    <button
      class="ml-6 flex-none border border-foreground px-6 py-3 font-mono-ui text-sm tracking-wide transition hover:border-gold hover:bg-gold hover:text-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background"
      type="submit"
    >
      Join
    </button>
  </div>
</form>

<script is:inline>
  (function () {
    var form = document.querySelector('form[action*="convertkit"]');
    if (!form) return;
    form.addEventListener('submit', function () {
      var email = form.querySelector('input[name="email_address"]');
      if (email && email.value) {
        window.posthog?.identify(email.value);
      }
      window.posthog?.capture('newsletter_form_submitted');
    });
  })();
</script>
