---
import { getCollection } from 'astro:content';
import GermanLayout from '../../../layouts/GermanLayout.astro';
import Badge from '../../../components/ui/Badge.astro';
import Button from '../../../components/ui/Button.astro';

const projects = (await getCollection('projekte')).sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime()
);

const description = 'Beispielprojekte aus Gastronomie, Dienstleistung und Consumer-Apps. Von der Idee bis zum Launch — mit Festpreis und Werkvertrag.';
---

<GermanLayout
  title="Projekte — Khaled Garbaya"
  description={description}
>
  <main class="font-sans">
    <section class="container mx-auto max-w-2xl lg:max-w-5xl px-4 pt-24 pb-12">
      <h1 class="text-5xl font-bold leading-tight tracking-tight">Projekte</h1>
      <p class="mt-6 text-lg text-muted-foreground">{description}</p>
    </section>

    <section class="container mx-auto max-w-2xl lg:max-w-5xl px-4 pb-20">
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((p) => (
          <li>
            <a
              href={`/de/projekte/${p.slug}`}
              class="block h-full rounded-2xl border border-border bg-card p-6 transition-all hover:border-cerulean hover:shadow-md"
            >
              <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <span>{p.data.branche}</span>
                <span>·</span>
                <span>{p.data.kunde}</span>
              </div>
              <h2 class="mt-3 text-2xl font-semibold tracking-tight text-foreground">
                {p.data.title}
              </h2>
              <p class="mt-3 text-muted-foreground">{p.data.zusammenfassung}</p>
              {p.data.tags.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {p.data.tags.map((t) => (
                    <Badge>{t}</Badge>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-16 text-center">
        <p class="text-lg">Dein Projekt passt nicht ganz in diese Beispiele?</p>
        <div class="mt-6">
          <Button href="/de/kontakt" size="lg">Erstgespräch vereinbaren</Button>
        </div>
      </div>
    </section>
  </main>
</GermanLayout>
