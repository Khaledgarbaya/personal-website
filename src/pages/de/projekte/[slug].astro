---
import { getCollection, type CollectionEntry } from 'astro:content';
import GermanLayout from '../../../layouts/GermanLayout.astro';
import Badge from '../../../components/ui/Badge.astro';
import Button from '../../../components/ui/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projekte');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projekte'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<GermanLayout
  title={`${project.data.title} — Projekte`}
  description={project.data.zusammenfassung}
>
  <main class="font-sans">
    <article class="container mx-auto max-w-2xl lg:max-w-4xl px-4 pt-24 pb-12">
      <a href="/de/projekte" class="text-sm text-cerulean hover:underline">← Alle Projekte</a>

      <header class="mt-6">
        <div class="flex items-center gap-2 text-sm text-muted-foreground">
          <span>{project.data.branche}</span>
          <span>·</span>
          <span>{project.data.kunde}</span>
        </div>
        <h1 class="mt-3 text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
          {project.data.title}
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">{project.data.zusammenfassung}</p>
        {project.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {project.data.tags.map((t) => (
              <Badge>{t}</Badge>
            ))}
          </div>
        )}
        {project.data.externalUrl && (
          <div class="mt-6">
            <a
              href={project.data.externalUrl}
              class="inline-flex items-center text-cerulean hover:underline font-medium"
              rel="external"
            >
              Projekt ansehen
              <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
              </svg>
            </a>
          </div>
        )}
      </header>

      <div class="mt-12 prose dark:prose-invert prose-lg max-w-none">
        <Content />
      </div>
    </article>

    <section class="container mx-auto max-w-2xl lg:max-w-4xl px-4 pb-20 text-center">
      <div class="rounded-2xl border border-border bg-card p-10">
        <h2 class="text-3xl font-semibold tracking-tight">Ähnliches Projekt im Kopf?</h2>
        <p class="mt-3 text-muted-foreground">Lass uns in einem kostenlosen Erstgespräch klären, was möglich ist.</p>
        <div class="mt-6">
          <Button href="/de/kontakt" size="lg">Anfrage senden</Button>
        </div>
      </div>
    </section>
  </main>
</GermanLayout>
