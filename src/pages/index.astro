---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MainHero from '../components/MainHero.astro';
import RecentPosts from '../components/RecentPosts.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import WebsiteSchema from '../components/schemas/WebsiteSchema.astro';
import PersonSchema from '../components/schemas/PersonSchema.astro';

// Get the 5 most recent posts
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) =>
  b.data.published.getTime() - a.data.published.getTime()
).slice(0, 5);

const statements = [
  {
    line: 'I lead engineering teams.',
    caption: 'Senior Engineering Manager at Staffbase — communities, mobile, and a plugin platform built for the agent era.',
  },
  {
    line: 'I ship with agents.',
    caption: 'Specs, plans, reviews, phase gates — I manage AI agents the way I manage engineers.',
  },
  {
    line: 'I write about what that changes.',
    caption: 'Agentic workflows, engineering leadership, and the craft in between.',
  },
];
---

<BaseLayout>
  <WebsiteSchema slot="head" />
  <PersonSchema slot="head" />

  <!-- START: Homepage -->
  <!-- CONTENT_TYPE: Homepage -->
  <!-- AUTHOR: Khaled Garbaya -->
  <MainHero />

  <main>
    <!-- Statement stanzas -->
    <section class="px-6 sm:px-10" aria-label="What I do">
      <div class="mx-auto max-w-7xl">
        {statements.map((statement, i) => (
          <div class:list={['reveal py-[16vh]', i > 0 && 'border-t border-border']}>
            <h2 class="display-huge text-[clamp(2.25rem,6vw,5.5rem)]">
              {statement.line}
            </h2>
            <p class="mt-6 max-w-xl text-lg text-muted-foreground" style={`--reveal-delay: 150ms`}>
              {statement.caption}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Latest writing -->
    <section class="px-6 pt-[10vh] sm:px-10" aria-label="Latest blog posts">
      <div class="mx-auto max-w-7xl">
        <div class="reveal flex items-baseline justify-between border-b border-border pb-6">
          <h2 class="display-huge text-[clamp(2.25rem,6vw,5.5rem)]">Latest writing</h2>
          <a
            href="/blog"
            class="font-mono-ui text-sm tracking-wide text-muted-foreground transition hover:text-gold"
          >
            All posts →
          </a>
        </div>
        <RecentPosts posts={sortedPosts} />
      </div>
    </section>

    <!-- Newsletter band -->
    <section class="px-6 py-[16vh] sm:px-10" aria-label="Newsletter">
      <div class="reveal mx-auto max-w-7xl">
        <NewsletterForm />
      </div>
    </section>
  </main>
  <!-- END: Homepage -->
</BaseLayout>
